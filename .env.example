# Ruta raíz del dataset. Debe contener las carpetas raw/, clean/, etc.
# - Servidor: ruta del volumen montado (p.ej. /mnt/datasets/data/corn-leaf-diseases)
# - Local: cualquier ruta de tu máquina donde tengas el dataset descargado
#
# Ejemplos por sistema operativo (usa solo una línea, la que aplique a tu entorno):
#   Linux/servidor: DATASET_ROOT=/mnt/datasets/data/corn-leaf-diseases
#   macOS:          DATASET_ROOT=/Users/tu_usuario/datasets/corn-leaf-diseases
#   Windows:         DATASET_ROOT=C:/Users/tu_usuario/datasets/corn-leaf-diseases
#   Instancia vast.ai: DATASET_ROOT=/workspace/data
DATASET_ROOT=/mnt/datasets/data/corn-leaf-diseases

# --- Descarga/subida del dataset limpio (scripts/dataset/) -----------------
# Fuente primaria: Hugging Face Datasets Hub (repo tipo dataset con el árbol clean/).
# HF_TOKEN solo hace falta si el repo es privado o no hiciste `huggingface-cli login`.
HF_DATASET_REPO=tu_usuario/corn-leaf-clean
HF_TOKEN=

# Fuente de respaldo: carpeta pública de Google Drive con el mismo árbol clean/.
GDRIVE_DATASET_ID=